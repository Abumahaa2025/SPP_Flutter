# SPP Beta — Backend (copy to .env)
SPP_BETA_MODE=true
SPP_DEMO_MODE=false
SPP_DATA_SOURCE=mongo

# CRITICAL — leave empty in beta so real Google Sheets tenants never appear
GOOGLE_APPS_SCRIPT_URL=
SPP_API_KEY=

# Optional Mongo (recommended for production beta host)
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=spp_beta

# AI (optional — Brain chat works when set)
# EMERGENT_LLM_KEY=your-key
