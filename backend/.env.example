# Mongo (demo / fallback)
MONGO_URL=mongodb://localhost:27017
DB_NAME=spp

# Demo seed — off by default (production: empty portfolio until owner adds data)
SPP_DEMO_MODE=false

# Emergent LLM (chat — unchanged in Phase 4)
EMERGENT_LLM_KEY=

# Google Apps Script — Phase 4 live data (read-only, lite actions)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyfGVaod79j2J7QytcDcTiyx7oh5ioQODLBkARZ5-vVjTg7EiW2g1SzNZeKjxp3Pbv1rQ/exec
SPP_API_KEY=

# Global default when per-domain flag omitted
SPP_DATA_SOURCE=hybrid

# Per-domain source: mongo | gas | hybrid (gas first, mongo fallback)
SPP_PROPERTIES_SOURCE=hybrid
SPP_TENANTS_SOURCE=hybrid
SPP_CONTRACTS_SOURCE=hybrid
SPP_DECISIONS_SOURCE=hybrid
SPP_REPORTS_SOURCE=hybrid
SPP_ALERTS_SOURCE=hybrid
